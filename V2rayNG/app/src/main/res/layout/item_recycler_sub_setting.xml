<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    android:gravity="center_vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="?attr/colorCard"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/info_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textSize="17sp"
                app:layout_constraintBottom_toBottomOf="@id/chk_enable"
                app:layout_constraintEnd_toStartOf="@id/chk_enable"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/chk_enable" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/chk_enable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:thumbIcon="@drawable/mtrl_ic_check" />

            <TextView
                android:id="@+id/tv_url"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="3"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/chk_enable" />

            <com.google.android.material.chip.Chip
                android:id="@+id/tv_last_updated"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginTop="12dp"
                android:checkable="false"
                android:clickable="false"
                android:focusable="false"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textSize="12sp"
                app:chipBackgroundColor="?attr/colorSecondaryContainer"
                app:chipMinTouchTargetSize="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_url" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/layout_share"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_button" 
                android:contentDescription="@string/title_configuration_share"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="@id/tv_last_updated"
                app:layout_constraintEnd_toStartOf="@id/layout_edit"
                app:layout_constraintTop_toTopOf="@id/tv_last_updated"
                app:srcCompat="@drawable/ic_share_color"
                app:tint="@null" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/layout_edit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_button" 
                android:contentDescription="@string/menu_item_edit_config"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="@id/tv_last_updated"
                app:layout_constraintEnd_toStartOf="@id/layout_remove"
                app:layout_constraintTop_toTopOf="@id/tv_last_updated"
                app:srcCompat="@drawable/ic_edit_color"
                app:tint="@null" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/layout_remove"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_button" 
                android:contentDescription="@string/menu_item_del_config"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="@id/tv_last_updated"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_last_updated"
                app:srcCompat="@drawable/ic_delete_empty"
                app:tint="?attr/colorError" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
