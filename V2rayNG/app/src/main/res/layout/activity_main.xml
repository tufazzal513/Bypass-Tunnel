<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/banner_home"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/header_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/uwu_banner_image_about"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/header_image_fade"
            android:background="@drawable/uwu_bg_fade_bottom"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        android:layout_alignParentTop="true">

        <LinearLayout
            android:id="@+id/header_content"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/header_top_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="3dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="55dp"
                        android:minHeight="55dp"
                        app:backgroundTint="?colorCard"
                        app:icon="@drawable/ic_btn_home_color"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@null"
                        style="@style/Widget.Material3Expressive.Button.IconButton.Filled" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_more_menu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="55dp"
                        android:minHeight="55dp"
                        app:backgroundTint="?colorCard"
                        app:icon="@drawable/ic_btn_more_menu_color"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@null"
                        style="@style/Widget.Material3Expressive.Button.IconButton.Filled" />
                </LinearLayout>

                <LinearLayout
                    android:gravity="end|center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="10dp">

                    <com.neko.marquee.text.Greetings
                        android:id="@+id/tv_greeting_sub"
                        android:textAppearance="?textAppearanceBodySmall"
                        android:textStyle="bold"
                        android:textColor="?colorOnSurfaceVariant"
                        android:ellipsize="marquee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever" />

                    <com.neko.marquee.text.UserNameTextView
                        android:id="@+id/tv_username"
                        android:textAppearance="?textAppearanceTitleMedium"
                        android:textStyle="bold"
                        android:textColor="?colorOnSurface"
                        android:ellipsize="marquee"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever" />
                </LinearLayout>

                <com.neko.widget.ProfileBannerImageView
                    android:id="@+id/iv_profile"
                    android:background="@android:color/transparent"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:elevation="0dp"
                    android:outlineProvider="none"
                    app:elevation="0dp"
                    app:siBorderColor="?colorPrimary"
                    app:siBorderWidth="3dp" />
            </LinearLayout>

            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="3dp"
                android:paddingBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_config"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="55dp"
                    android:minHeight="55dp"
                    android:layout_marginEnd="4dp"
                    app:backgroundTint="?colorCard"
                    app:icon="@drawable/ic_btn_add_config_color"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@null"
                    style="@style/Widget.Material3Expressive.Button.IconButton.Filled" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="?colorCard"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="14dp"
                        android:paddingRight="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:src="@drawable/ic_aim_color" />

                        <androidx.appcompat.widget.SearchView
                            android:id="@+id/search_view_inline"
                            android:background="@android:color/transparent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:closeIcon="@null"
                            app:iconifiedByDefault="false"
                            app:queryBackground="@android:color/transparent"
                            app:queryHint="@string/menu_item_search_main"
                            app:searchIcon="@null" />

                        <LinearLayout
                            android:id="@+id/layout_weather_chip"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_weather_chip"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="8dp"
                            android:paddingEnd="10dp"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/iv_weather_icon"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_weather_sunny"
                                android:tint="?colorOnSurfaceVariant"
                                android:visibility="gone" />


                            <TextView
                                android:id="@+id/tv_weather_temp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textAppearance="?textAppearanceBodySmall"
                                android:textColor="?colorOnSurfaceVariant"
                                android:textSize="13sp"
                                android:visibility="gone"
                                tools:text="29°C" />

                            <ImageView
                                android:id="@+id/iv_total_traffic_icon"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_traffic_total"
                                android:tint="?colorOnSurfaceVariant"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tv_total_traffic"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textAppearance="?textAppearanceBodySmall"
                                android:textColor="?colorOnSurfaceVariant"
                                android:textSize="13sp"
                                android:visibility="gone"
                                tools:text="1.2 GB" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/app_bar">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:scrollbars="vertical"
            android:nextFocusRight="@+id/fab"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/uwu_bg_fade_top" />

        <LinearLayout
            android:id="@+id/layout_tab_wrapper"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="?colorCard"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:contentPadding="5dp"
                app:strokeWidth="0dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="23dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:clipToOutline="true"
                    android:clipChildren="true">

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tab_group"
                        android:background="@android:color/transparent"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        app:tabIndicator="@drawable/uwu_tabs_rounded_indicator"
                        app:tabIndicatorAnimationMode="elastic"
                        app:tabIndicatorColor="?colorPrimary"
                        app:tabIndicatorFullWidth="true"
                        app:tabIndicatorHeight="40dp"
                        app:tabMinWidth="0dp"
                        app:tabMode="scrollable"
                        app:tabPaddingEnd="0dp"
                        app:tabPaddingStart="0dp"
                        app:tabRippleColor="@android:color/transparent"
                        app:tabSelectedTextAppearance="?textAppearanceTitleSmall"
                        app:tabSelectedTextColor="?colorSurface"
                        app:tabTextAppearance="?textAppearanceTitleSmall"
                        app:tabTextColor="?colorOnSurfaceVariant" />

                </com.google.android.material.card.MaterialCardView>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="55dp"
                android:minHeight="55dp"
                android:layout_marginStart="4dp"
                app:backgroundTint="?colorPrimary"
                app:icon="@drawable/ic_add_circle_fill_24px"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="?colorOnPrimary"
                style="@style/Widget.Material3Expressive.Button.IconButton.Filled" />
        </LinearLayout>

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/uwu_bg_fade_bottom" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_bottom_status"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <com.qmdeve.blurview.widget.BlurView
            android:id="@+id/blur_bottom_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:blurRadius="20dp"
            app:cornerRadius="28dp"
            app:overlayColor="@color/uwu_tint_blur" />

        <RelativeLayout
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/status_text_container"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@+id/fab_container"
                android:layout_alignParentStart="true">

                <TextView
                    android:id="@+id/tv_ip_state"
                    android:textAppearance="?textAppearanceTitleSmall"
                    android:textSize="12sp"
                    android:textColor="?colorOnSurfaceVariant"
                    android:ellipsize="end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true" />

                <com.neko.marquee.text.AutoMarqueeTextView
                    android:id="@+id/tv_test_state"
                    android:textAppearance="?textAppearanceTitleMedium"
                    android:textSize="17sp"
                    android:textColor="?colorOnSurface"
                    android:ellipsize="marquee"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/connection_test_pending"
                    android:singleLine="true"
                    android:marqueeRepeatLimit="marquee_forever" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/fab_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_play_24dp"
                    android:elevation="0dp"
                    android:outlineProvider="none"
                    app:elevation="0dp"
                    app:backgroundTint="?colorPrimary"
                    app:tint="?colorOnPrimary"
                    style="?floatingActionButtonStyle" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab_no_blur"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_play_24dp"
                    android:elevation="0dp"
                    android:outlineProvider="none"
                    app:elevation="0dp"
                    app:backgroundTint="?colorOnPrimary"
                    app:tint="?colorPrimary"
                    style="?floatingActionButtonStyle" />
            </FrameLayout>
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>
