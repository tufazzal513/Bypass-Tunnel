<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16.0dp">

    <FrameLayout
        android:layout_width="45.0dp"
        android:layout_height="45.0dp">
        
        <com.neko.widget.DynamicShapeImageView
            app:shapeBackgroundColor="?colorPrimary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />
            
        <androidx.preference.internal.PreferenceImageView
            android:id="@android:id/icon"
            android:layout_width="25.0dp"
            android:layout_height="25.0dp"
            android:layout_gravity="center"
            android:tint="?colorOnPrimary" />
    </FrameLayout>
    
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingTop="10.0dp"
        android:paddingBottom="10.0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">
            
            <TextView
                android:id="@android:id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="false"
                android:textAppearance="?textAppearanceTitleMedium"
                android:textColor="?colorOnSurface"
                android:textSize="17.0sp" />
                
            <TextView
                android:id="@android:id/summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4.0dp"
                android:singleLine="false"
                android:textAppearance="?textAppearanceTitleSmall"
                android:textColor="?colorOnSurfaceVariant"
                android:textSize="14.0sp" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end|bottom">
        
        <com.google.android.material.card.MaterialCardView
            android:layout_width="28.0dp"
            android:layout_height="28.0dp"
            app:cardBackgroundColor="?colorSurfaceContainerHighest"
            app:cardCornerRadius="99.0dp"
            app:cardElevation="0.0dp"
            app:strokeWidth="0.0dp">
            
            <ImageView
                android:layout_width="25.0dp"
                android:layout_height="25.0dp"
                android:layout_gravity="center"
                android:src="@drawable/uwu_arrow"
                android:tint="?colorOnSurfaceVariant" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>
