<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:id="@+id/item_bg"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4.0dip"
    android:layout_marginBottom="4.0dip"
    android:layout_marginStart="16.0dip"
    android:layout_marginEnd="16.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_card"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?colorCard"
        app:cardCornerRadius="14.0dip"
        app:cardElevation="0.0dip"
        app:strokeColor="?colorOutlineVariant"
        app:strokeWidth="0.0dip">
        <LinearLayout
            android:id="@+id/layout_indicator"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/info_container"
                android:paddingTop="12.0dip"
                android:paddingBottom="12.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="4.0dip"
                android:paddingEnd="4.0dip">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingStart="8.0dip"
                    android:paddingEnd="8.0dip">
                    <TextView
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textSize="17.0sp"
                        android:textColor="?colorOnSurface"
                        android:id="@+id/tv_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1" />
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4.0dip">
                        <com.google.android.material.chip.Chip
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="?colorOnSecondaryContainer"
                            android:textSize="12.0sp"
                            android:id="@+id/tv_type"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="28.0dip"
                            android:checkable="false"
                            android:layout_marginEnd="8.0dip"
                            app:chipBackgroundColor="?colorSecondaryContainer"
                            app:chipMinTouchTargetSize="0.0dip" />
                        <LinearLayout
                            android:id="@+id/layout_subscription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <com.google.android.material.chip.Chip
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="?colorOnTertiaryContainer"
                            android:textSize="12.0sp"
                            android:id="@+id/tv_subscription"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="28.0dip"
                            android:checkable="false"
                            android:layout_marginEnd="8.0dip"
                            app:chipBackgroundColor="?colorTertiaryContainer"
                            app:chipMinTouchTargetSize="0.0dip" />
                        <View
                            android:layout_width="0.0dip"
                            android:layout_height="0.0dip"
                            android:layout_weight="1.0" />
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <androidx.appcompat.widget.AppCompatImageButton
                                android:id="@+id/layout_share"
                                android:layout_width="40.0dip"
                                android:layout_height="40.0dip"
                                android:contentDescription="@string/title_configuration_share"
                                android:background="?selectableItemBackgroundBorderless"
                                android:focusable="true"
                                app:srcCompat="@drawable/ic_share_24dp"
                                app:tint="?colorOnSurfaceVariant" />
                            <androidx.appcompat.widget.AppCompatImageButton
                                android:id="@+id/layout_edit"
                                android:layout_width="40.0dip"
                                android:layout_height="40.0dip"
                                android:contentDescription="@string/menu_item_edit_config"
                                android:background="?selectableItemBackgroundBorderless"
                                android:focusable="true"
                                app:srcCompat="@drawable/ic_edit_24dp"
                                app:tint="?colorOnSurfaceVariant" />
                            <androidx.appcompat.widget.AppCompatImageButton
                                android:id="@+id/layout_remove"
                                android:layout_width="40.0dip"
                                android:layout_height="40.0dip"
                                android:contentDescription="@string/menu_item_del_config"
                                android:background="?selectableItemBackgroundBorderless"
                                android:focusable="true"
                                app:srcCompat="@drawable/ic_delete_24dp"
                                app:tint="?colorError" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4.0dip">
                        <TextView
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textSize="14.0sp"
                            android:textColor="?colorOnSurfaceVariant"
                            android:id="@+id/tv_statistics"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:lines="1" />
                         <View
                            android:layout_width="0.0dip"
                            android:layout_height="0.0dip"
                            android:layout_weight="1.0" />
                        <TextView
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textSize="14.0sp"
                            android:textColor="@color/colorPing"
                            android:id="@+id/tv_test_result"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:lines="1" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tv_traffic"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textSize="11.0sp"
                        android:textColor="?colorOnSurfaceVariant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="2.0dip"
                        android:visibility="gone"
                        android:lines="1" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
