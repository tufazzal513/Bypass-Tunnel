<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="top"
        android:height="26.0dip">
        <shape>
            <gradient
                android:startColor="?colorCard"
                android:endColor="?colorPrimary"
                android:angle="45.0"
                android:type="linear" />
            <corners
                android:radius="16.0dip" />
        </shape>
    </item>
    <item
        android:gravity="bottom"
        android:height="26.0dip">
        <shape>
            <gradient
                android:startColor="?colorPrimary"
                android:endColor="?colorCard"
                android:angle="45.0"
                android:type="linear" />
            <corners
                android:radius="16.0dip" />
        </shape>
    </item>
    <item
        android:top="4.0dip"
        android:bottom="4.0dip">
        <inset>
            <shape
                android:shape="rectangle">
                <solid
                    android:color="?colorCard" />
                <corners
                    android:radius="16.0dip" />
            </shape>
        </inset>
    </item>
</layer-list>
