<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppThemeBase" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.LargeComponent</item>
        <item name="android:colorBackground">?colorBg</item>
        <item name="android:windowBackground">?colorBg</item>
        <item name="colorBg">?colorSurfaceVariant</item>
        <item name="colorCard">?colorSurfaceContainerLow</item>
        <item name="bottomSheetDialogTheme">@style/AppThemeBottomSheetDialog</item>
        <item name="materialAlertDialogTheme">@style/AppThemeAlertDialog</item>
        <item name="alertDialogTheme">@style/AppThemeAlertDialog</item>
        <item name="android:scrollbarSize">0.0dip</item>
        <item name="android:listDivider">@null</item>
        <item name="android:colorEdgeEffect">@null</item>
        <item name="elevation">0.0dip</item>
        <item name="preferenceTheme">@style/AppThemePreference</item>
        <item name="android:homeAsUpIndicator">@drawable/uwu_back_arrow</item>
    </style>
    
    <style name="AppThemePreference" parent="@style/PreferenceThemeOverlay">
        <item name="editTextPreferenceStyle">@style/AppThemeEditTextPreference</item>
        <item name="preferenceCategoryStyle">@style/AppThemePreferenceCategory</item>
    </style>
    <style name="AppThemeEditTextPreference" parent="@style/Preference.DialogPreference.EditTextPreference.Material">
        <item name="dialogLayout">@layout/uwu_dialog_edittext</item>
        <item name="iconSpaceReserved">false</item>
    </style>
    <style name="AppThemePreferenceCategory" parent="@style/Preference.Category.Material">
        <item name="android:layout">@layout/uwu_preference_category</item>
        <item name="allowDividerAbove">false</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <!-- Bottom Sheet -->
    <style name="AppThemeBottomSheetDialog" parent="@style/ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:colorBackground">@drawable/uwu_background_bottom_sheet</item>
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowAnimationStyle">@style/Animation.Material3.BottomSheetDialog</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">?attr/colorBg</item>
        <item name="android:windowElevation">0.0dip</item>
        <item name="bottomSheetStyle">@style/AppThemeBottomSheetStyle</item>
        <item name="paddingBottomSystemWindowInsets">true</item>
        <item name="paddingLeftSystemWindowInsets">false</item>
        <item name="paddingRightSystemWindowInsets">false</item>
    </style>

    <style name="AppThemeBottomSheetStyle" parent="@style/Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">?attr/colorBg</item>
        <item name="shapeAppearance">@style/AppThemeBottomSheetShape</item>
    </style>

    <style name="AppThemeBottomSheetShape" parent="@style/ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">35dp</item>
        <item name="cornerSizeTopRight">35dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Alert Dialog -->
    <style name="AppThemeAlertDialog" parent="@style/ThemeOverlay.Material3Expressive.MaterialAlertDialog">
        <item name="shapeAppearance">@style/AppThemeAlertDialogShape</item>
        <item name="backgroundTint">?attr/colorSurfaceContainer</item>
        <item name="colorSurface">?attr/colorSurfaceContainer</item>
        <item name="android:backgroundTint">?attr/colorSurfaceContainer</item>
        <item name="android:background">?attr/colorSurfaceContainer</item>
        <item name="android:colorBackground">?attr/colorSurfaceContainer</item>
        <item name="android:colorBackgroundFloating">?attr/colorSurfaceContainer</item>
        <item name="android:dialogCornerRadius">28.0dip</item>
        <item name="colorBackgroundFloating">?attr/colorSurfaceContainer</item>
        <item name="dialogCornerRadius">28.0dip</item>
    </style>

    <style name="AppThemeAlertDialogShape" parent="@style/ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <!-- Translucent for dialogs/overlays -->
    <style name="AppThemeDayNight.NoActionBar.Translucent" parent="@style/AppThemeBase">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <!-- Switch uses primary violet -->
    <style name="BrandedSwitch" parent="AppThemeBase">
        <item name="colorPrimary">@color/color_fab_active</item>
    </style>

    <!-- Shape appearances (M3 standard radii) -->
    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Tab text style -->
    <style name="TabLayoutTextStyle" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/montserrat_thin</item>
    </style>

    <style name="AppThemeFabSquare" parent="@style/AppThemeBase">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">15.0dip</item>
    </style>

    <!-- True Black overlay: applied on top of any theme when dark mode + true black enabled -->
    <style name="ThemeOverlay.App.TrueBlack" parent="@style/ThemeOverlay.Material3Expressive">
        <item name="android:colorBackground">#ff000000</item>
        <item name="colorBg">#ff000000</item>
        <item name="colorCard">#ff131313</item>
        <item name="colorSurface">#ff000000</item>
        <item name="colorSurfaceVariant">#ff1a1a1a</item>
        <item name="colorSurfaceContainerLow">#ff131313</item>
        <item name="colorSurfaceContainerHigh">#ff212121</item>
        <item name="colorSurfaceContainerHighest">#ff212121</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.App.TrueBlack.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.TrueBlack.AlertDialog</item>
    </style>

    <style name="ThemeOverlay.App.TrueBlack.AlertDialog" parent="@style/ThemeOverlay.Material3Expressive.MaterialAlertDialog">
        <item name="shapeAppearance">@style/AppThemeAlertDialogShape</item>
        <item name="backgroundTint">#ff131313</item>
        <item name="colorSurface">#ff131313</item>
        <item name="android:backgroundTint">#ff131313</item>
        <item name="android:background">#ff131313</item>
        <item name="android:colorBackground">#ff131313</item>
        <item name="android:colorBackgroundFloating">#ff131313</item>
        <item name="colorBackgroundFloating">#ff131313</item>
        <item name="android:dialogCornerRadius">28.0dip</item>
    </style>
    
    <style name="AppThemeCrashLogger" parent="@style/AppThemeBase">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

</resources>