<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="colorBg" format="color" />
    <attr name="colorCard" format="color" />
    
    <attr name="siArrowPosition">
        <enum name="left" value="0" />
        <enum name="right" value="1" />
    </attr>
    <attr name="siBorderType">
        <enum name="stroke" value="0" />
        <enum name="fill" value="1" />
    </attr>
    <attr name="siStrokeCap">
        <enum name="butt" value="0" />
        <enum name="round" value="1" />
        <enum name="square" value="2" />
    </attr>
    <attr name="siStrokeJoin">
        <enum name="bevel" value="0" />
        <enum name="miter" value="1" />
        <enum name="round" value="2" />
    </attr>
    <declare-styleable name="ShaderImageView">
        <attr name="siSquare" format="boolean" />
        <attr name="siBorderColor" format="color" />
        <attr name="siBorderWidth" format="dimension" />
        <attr name="siBorderAlpha" format="float" />
        <attr name="siForeground" format="integer|reference" />
        <attr name="siRadius" format="dimension" />
        <attr name="siArrowPosition"/>
        <attr name="siTriangleHeight" format="dimension"/>
        <attr name="siShape" format="integer|reference" />
        <attr name="siBorderType"/>
        <attr name="siStrokeCap"/>
        <attr name="siStrokeJoin"/>
        <attr name="siStrokeMiter" format="dimension" />
    </declare-styleable>
    
    <declare-styleable name="ExpandableView">
        <attr name="el_duration" format="integer" />
        <attr name="el_expanded" format="boolean" />
        <attr name="el_parallax" format="float" />
        <attr name="el_orientation" format="enum">
            <enum name="horizontal" value="0" />
            <enum name="vertical" value="1" />
        </attr>
    </declare-styleable>
    
    <declare-styleable name="DynamicShapeImageView">
        <attr name="shapeBackgroundColor" format="color|reference" />
    </declare-styleable>
    
    <declare-styleable name="UwuHeaderIconView">
        <attr name="sectionIcon" format="reference" />
    </declare-styleable>

    <declare-styleable name="ParticlesView">
        <attr
            name="minDotRadius"
            format="dimension" />
        <attr
            name="maxDotRadius"
            format="dimension" />
        <attr
            name="lineThickness"
            format="dimension" />
        <attr
            name="lineDistance"
            format="dimension" />
        <attr
            name="numDots"
            format="integer" />
        <attr
            name="dotColor"
            format="color" />
        <attr
            name="lineColor"
            format="color" />
        <attr
            name="frameDelayMillis"
            format="integer" />
        <attr
            name="stepMultiplier"
            format="float" />
    </declare-styleable>
    
</resources>
